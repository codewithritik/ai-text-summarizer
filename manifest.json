{
  "manifest_version": 3,
  "name": "AI Text Summarizer",
  "version": "1.0.0",
  "description": "Summarize selected text using Google AI",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}

